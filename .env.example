# PostgreSQL
# Set DATABASE_URL or use the individual POSTGRES_* fields below.
DATABASE_URL=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=produtividade
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_SSLMODE=

# Jira
JIRA_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_TOKEN=replace-with-a-new-token
JIRA_SQUAD_FIELD=customfield_10431
JIRA_SPRINT_FIELD=customfield_10010
JIRA_CROSSING_FIELD=customfield_10894

# Clockify
CLOCKIFY_API_KEY=replace-with-a-new-key
CLOCKIFY_WORKSPACE_ID=replace-with-workspace-id

# Optional cron monitoring (for example, a Healthchecks.io ping URL).
# Keep this URL secret and leave it empty until the check is created.
ETL_HEALTHCHECK_URL=
ETL_RETRIES=1
ETL_RETRY_DELAY=30
